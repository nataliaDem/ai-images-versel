{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "fluid": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' *"
        }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 300
    }
  }
}
